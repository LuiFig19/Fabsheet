# Copy to .env and fill in. Never commit the real .env. On Vercel, set these in
# the project's Environment Variables, not in a committed file.

# --- Tenancy ---
APP_MODE=single_tenant              # single_tenant (one company) or multi_tenant
DEFAULT_TENANT_SLUG=ravens          # used in single_tenant mode
ACCESS_PATH_PREFIX=r/8h3kd92ksjf    # required URL prefix in single_tenant mode
APP_SECRET=                         # random 32+ char string; signs sessions + encrypts keys

# --- Database (Neon in prod) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# --- OCR (Claude Vision) ---
EXTRACTOR=claude                    # claude (real) or mock (dev)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
DAILY_OCR_CAP=100

# --- Storage (Cloudflare R2, S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=fabsheet-ravens
R2_PUBLIC_URL=                      # optional public bucket URL; else signed URLs are used

# --- Email (Resend) ---
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=ravens@fabsheet.org
DEFAULT_TO_EMAILS=hr@ravensmarine.com,office@ravensmarine.com

# --- App ---
NEXT_PUBLIC_APP_NAME=FabSheet
NEXT_PUBLIC_APP_URL=https://fabsheet.org
